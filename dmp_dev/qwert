-- Убери transactiontypecode из группировки (дедуп ключ = 4 поля, не 5)
WITH CNT AS (
    SELECT businessdaydate, retailstoreid, workstationid, transactionsequencenumber, count(*) as qnty
    FROM ice_baby.core_flow_ing_raw.raw_bptransaction_test
    WHERE DATE(businessdaydate) IN (DATE '2026-03-17', DATE '2026-03-18')
    GROUP BY businessdaydate, retailstoreid, workstationid, transactionsequencenumber
)
SELECT DATE(businessdaydate) as day, count(*) as duplicates, sum(qnty) as total_rows
FROM CNT
WHERE qnty > 1
GROUP BY DATE(businessdaydate)
ORDER BY day

