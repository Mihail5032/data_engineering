SELECT rtl_txn_rk, businessdaydate, retailstoreid, workstationid, 
       transactionsequencenumber, load_ts
FROM ice_baby.core_flow_ing_raw.raw_bptransaction_test
WHERE DATE(businessdaydate) = DATE '2026-03-17'
  AND (businessdaydate, retailstoreid, workstationid, transactionsequencenumber) IN (
      SELECT businessdaydate, retailstoreid, workstationid, transactionsequencenumber
      FROM ice_baby.core_flow_ing_raw.raw_bptransaction_test
      WHERE DATE(businessdaydate) = DATE '2026-03-17'
      GROUP BY businessdaydate, retailstoreid, workstationid, transactionsequencenumber
      HAVING count(*) > 1
  )
ORDER BY retailstoreid, transactionsequencenumber, load_ts
LIMIT 20
