DEFINE add_fin_tran.
    UNASSIGN <fs_financialmovement>.
    IF l_value IS NOT INITIAL.
      l_ftypecode = &1.
      APPEND INITIAL LINE TO lt_fintran ASSIGNING <fs_transaction2>.
      <fs_transaction2>-transtypecode = '1301'.  " ПКО
      <fs_transaction2>-retailstoreid = ls_transaction-retailstoreid.
      <fs_transaction2>-businessdaydate = ls_transaction-businessdaydate.
      CONCATENATE ls_transaction-transnumber '_F' l_ftypecode INTO <fs_transaction2>-transnumber.
      <fs_transaction2>-begintimestamp = ls_transaction-begintimestamp.
      <fs_transaction2>-endtimestamp = ls_transaction-endtimestamp.
      <fs_transaction2>-transcurrency = 'RUB'.
      <fs_transaction2>-businesstype = /posdw/if_gen_constants=>businesstype_fi.

      APPEND INITIAL LINE TO <fs_transaction2>-financialmovement ASSIGNING <fs_financialmovement>.
      <fs_financialmovement>-finumber = '1'.
      <fs_financialmovement>-fitypecode = l_ftypecode.
      <fs_financialmovement>-amount = l_value.
      <fs_financialmovement>-ficurrency = 'RUB'.
    ENDIF.
  END-OF-DEFINITION.

