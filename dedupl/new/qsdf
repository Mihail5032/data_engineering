WITH CNT AS (
    SELECT 
        retailstoreid, 
        businessdaydate, 
        transactiontypecode, 
        workstationid, 
        transactionsequencenumber, 
        COUNT(*) as qnty
    FROM ice_baby.core_flow_ing_raw.raw_bptender
    GROUP BY 
        retailstoreid, 
        businessdaydate, 
        transactiontypecode, 
        workstationid, 
        transactionsequencenumber
    HAVING COUNT(*) > 1
)
SELECT 
    DATE(businessdaydate) as day,
    COUNT(*) as duplicate_count,
    SUM(qnty) as total_rows
FROM CNT
GROUP BY DATE(businessdaydate)
ORDER BY day DESC;
