 "INTEG-7710.Передадим суммы излишков сертификатов активного гражданина
    DATA lt_actgr TYPE tt_actgr.
    DATA cnum TYPE numc3.
    FIELD-SYMBOLS <actgr> TYPE t_actgr.
    CLEAR cnum.
    LOOP AT <fs_transaction>-extensions ASSIGNING <ext> WHERE fieldgroup CP 'CA*'.
      IF cnum <> <ext>-fieldgroup+2(3).
        APPEND INITIAL LINE TO lt_actgr ASSIGNING <actgr>.
      ENDIF.
      cnum = <ext>-fieldgroup+2(3).
      CASE <ext>-fieldname.
        WHEN 'CERT_AGRDT'.
          <actgr>-agrdate = <ext>-fieldvalue.
        WHEN 'CERT_AGRNM'.
          <actgr>-agrnum = <ext>-fieldvalue.
        WHEN 'CERT_PARTY'.
          <actgr>-party = <ext>-fieldvalue.
        WHEN 'CERT_PRINC'.
          <actgr>-princ = <ext>-fieldvalue.
        WHEN 'CERT_AMNT'.
          <actgr>-sum = <ext>-fieldvalue.
        WHEN 'CERT_DIFF'.
          <actgr>-dif = <ext>-fieldvalue.
      ENDCASE.
    ENDLOOP.

    LOOP AT lt_transaction INTO ls_transaction.
      LOOP AT ls_transaction-tender ASSIGNING <fs_tender>  WHERE tendertypecode = '3103' OR tendertypecode = '3105'.
        LOOP AT <fs_tender>-extensions ASSIGNING <fs_extensions> WHERE fieldname CP 'CER_*'.
          IF <fs_extensions>-fieldname = 'CER_OPTNOM'.
            l_value = <fs_extensions>-fieldvalue.
            add_fin_tran '3118'. " Сумма номин. сертиф. типа ОПТОВЫЙ
            l_value = l_value - <fs_tender>-tenderamount.
            add_fin_tran '3119'. " Разница номинала и факта при оплате ОПТ сертиф.
          ELSEIF <fs_extensions>-fieldname = 'CER_ROZNOM'.
            l_value = <fs_tender>-tenderamount.
            add_fin_tran '3116'. " Оплата сертификатами типа РОЗНИЧНЫЙ, факт
            l_value = <fs_extensions>-fieldvalue.
            l_value = l_value - <fs_tender>-tenderamount.
            add_fin_tran '3117'. " Разница номинала и факта при оплате РОЗН сертиф.
          ENDIF.
        ENDLOOP.
      ENDLOOP.
    ENDLOOP.

