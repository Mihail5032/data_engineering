FROM ice_baby.core_flow_ing_raw.raw_table_audit
WHERE datetime LIKE '%Mar 30%'
AND result LIKE '%<RETAILSTOREID>30SP</RETAILSTOREID>%'
AND result LIKE '%<TRANSACTIONSEQUENCENUMBER>100000000003724806</TRANSACTIONSEQUENCENUMBER>%'
LIMIT 1
