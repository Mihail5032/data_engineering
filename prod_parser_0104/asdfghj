SELECT rtl_txn_rk,
       retailstoreid,
       transactionsequencenumber,
       count(*) as cnt,
       count(DISTINCT _commit_snapshot_id) as snapshots
FROM raw_bptransaction_test
WHERE businessdaydate = '2026-03-21'
GROUP BY rtl_txn_rk, retailstoreid, transactionsequencenumber
HAVING count(*) > 1
LIMIT 15
