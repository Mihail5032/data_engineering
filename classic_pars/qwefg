
SELECT 
    retailstoreid, businessdaydate, workstationid, 
    transactionsequencenumber, tenderamount,
    COUNT(*) as cnt
FROM raw_bptender
WHERE businessdaydate >= '2026-03-28'
  AND tendertypecode = '3101'
GROUP BY retailstoreid, businessdaydate, workstationid, 
         transactionsequencenumber, tenderamount
HAVING COUNT(*) > 1
LIMIT 10;

