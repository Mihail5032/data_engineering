WITH dup_txns AS (
    SELECT retailstoreid, businessdaydate, workstationid, transactionsequencenumber
    FROM ice_baby.core_flow_ing_raw.raw_bptender
    WHERE tendertypecode = '3101'
    GROUP BY 1,2,3,4
    HAVING COUNT(*) > 1
    LIMIT 5
)
SELECT d.retailstoreid, d.transactionsequencenumber,
       t.tendertypecode, t.tendersequencenumber, t.tenderamount
FROM dup_txns d
JOIN ice_baby.core_flow_ing_raw.raw_bptender t
  ON d.retailstoreid = t.retailstoreid
 AND d.businessdaydate = t.businessdaydate
 AND d.workstationid = t.workstationid
 AND d.transactionsequencenumber = t.transactionsequencenumber
ORDER BY d.retailstoreid, d.transactionsequencenumber, t.tendertypecode
